# .env.example — Template public des variables d'environnement
#
# Ce fichier est un template SANS valeurs. Il peut etre committe sur Git.
# Pour utiliser : copie ce fichier en .env et remplis tes vraies valeurs.
#   cp .env.example .env

# ─── IA ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── Productivite ───────────────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ─── Google ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# ─── YouTube ────────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Deploiement ────────────────────────────────────────────────────────────────
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id_here
VERCEL_PROJECT_ID=your_vercel_project_id_here

# ─── Code ───────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username_here

# ─── Paiement ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
